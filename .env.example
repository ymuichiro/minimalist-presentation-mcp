# Local published port for compose localproxy.
APP_PORT=13000

# For Named Tunnel, set this to the public origin configured in Cloudflare.
# Example: https://message-first-deck.example.com
PUBLIC_BASE_URL=

# Host allowlist for MCP transport DNS rebinding protection.
# Include your Cloudflare Tunnel hostname before running make up-tunnel.
ALLOWED_HOSTS=127.0.0.1,localhost,app.internal

# Optional explicit Origin allowlist. When empty, origins are derived from ALLOWED_HOSTS.
ALLOWED_ORIGINS=

# OAuth redirect origin allowlist for dynamic client registration.
ALLOWED_REDIRECT_ORIGINS=https://chat.openai.com,https://chatgpt.com

# Required for make up-tunnel. Use a Cloudflare Named Tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=

LOG_LEVEL=INFO

# Enable this before exposing the server as an authenticated ChatGPT MCP app.
AUTH_ENABLED=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password

# Demo app: Communication Compiler API/UI under /example source tree.
APP_BASE_URL=http://localhost:8080
APP_ENV=local
APP_DATA_DIR=./data/app
AGENT_PROVIDER=mock

# Azure AI Foundry Agent. Required only when AGENT_PROVIDER=foundry.
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=
AZURE_AI_FOUNDRY_AGENT_NAME=
AZURE_AI_FOUNDRY_AGENT_VERSION=
AZURE_AI_FOUNDRY_AGENT_ID=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Azure Speech Service for demo voice input.
# Browser audio is uploaded to FastAPI, then transcribed server-side.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Optional keyless path. Use with Azure CLI/Managed Identity credentials.
AZURE_SPEECH_RESOURCE_ID=
# Optional. Defaults to https://<AZURE_SPEECH_REGION>.stt.speech.microsoft.com
AZURE_SPEECH_ENDPOINT=

# Demo app -> MCP integration.
MESSAGE_FIRST_MCP_ENDPOINT=http://localhost:3000/mcp
MESSAGE_FIRST_PUBLIC_BASE_URL=http://localhost:3000
MESSAGE_FIRST_MCP_BEARER_TOKEN=
MESSAGE_FIRST_MCP_ALLOW_LOCAL_FALLBACK=true

# Optional evidence fixture directory for demo grounding.
EVIDENCE_FIXTURE_DIR=./fixtures/evidence
