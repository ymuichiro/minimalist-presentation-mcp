# Local published port for compose localproxy.
APP_PORT=13000

# For Named Tunnel, set this to the public origin configured in Cloudflare.
# Example: https://message-first-deck.example.com
PUBLIC_BASE_URL=

# Host allowlist for MCP transport DNS rebinding protection.
# Include your Cloudflare Tunnel hostname before running make up-tunnel.
ALLOWED_HOSTS=127.0.0.1,localhost,app.internal

# Optional explicit Origin allowlist. When empty, origins are derived from ALLOWED_HOSTS.
ALLOWED_ORIGINS=

# Required for make up-tunnel. Use a Cloudflare Named Tunnel token.
CLOUDFLARE_TUNNEL_TOKEN=

LOG_LEVEL=INFO
