# Copy to .env.live and fill values before the paid Azure AI Foundry smoke test.
# This file is a template. Do not commit a filled .env.live.

# Demo app server
APP_BASE_URL=http://localhost:8080
APP_ENV=live-local
APP_DATA_DIR=./data/app-live

# Use the real Azure AI Foundry Agent adapter.
AGENT_PROVIDER=foundry

# Azure AI Foundry Projects 2.x endpoint.
# Find it in Foundry portal under the project overview / Libraries > Foundry.
# Expected shape: https://<resource-name>.ai.azure.com/api/projects/<project-name>
AZURE_AI_FOUNDRY_PROJECT_ENDPOINT=

# Preferred for current azure-ai-projects 2.x live test.
# Use the Agent name shown in Foundry, not the display-only UI title if they differ.
AZURE_AI_FOUNDRY_AGENT_NAME=

# Optional. Set only if you want a specific published/versioned Agent.
AZURE_AI_FOUNDRY_AGENT_VERSION=

# Legacy/classic fallback only. Current Projects 2.x should use AGENT_NAME above.
AZURE_AI_FOUNDRY_AGENT_ID=

# Optional. Useful for direct model smoke tests or agent creation, not required for invoking an existing Agent by name.
AZURE_OPENAI_DEPLOYMENT_NAME=

# Azure Speech Service for voice input.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# Optional keyless path. Use with Azure CLI/Managed Identity credentials.
AZURE_SPEECH_RESOURCE_ID=
# Optional. Defaults to https://<AZURE_SPEECH_REGION>.stt.speech.microsoft.com
AZURE_SPEECH_ENDPOINT=

# Local MCP server used by the demo backend.
MESSAGE_FIRST_MCP_ENDPOINT=http://localhost:3000/mcp
MESSAGE_FIRST_PUBLIC_BASE_URL=http://localhost:3000

# For the first live integration test, fail loudly instead of silently falling back to local rendering.
MESSAGE_FIRST_MCP_ALLOW_LOCAL_FALLBACK=false

# Leave empty unless the MCP server is auth-enabled and you have a valid bearer token for backend-to-MCP calls.
MESSAGE_FIRST_MCP_BEARER_TOKEN=

# Mock grounding fixtures remain local and free.
EVIDENCE_FIXTURE_DIR=./fixtures/evidence
